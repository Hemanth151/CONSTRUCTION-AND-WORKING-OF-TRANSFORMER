TRANSFORMER:

          # A Transformer is a static Device.Transformer is used to convert AC to DC.
          # The main purpose of Transformer is used to regulate voltage and control the frequency.
          #The coils in transformer are magnetically connected.
          # The Transformer works on the principle of mutual induction .The transformer are high efficient Devices.
TYPES OF COILS:
              # PRIMARY COIL
              #SECONDARY COIL
WORKING OF TRANSFORMER:
                       #BOTH THE COILS ARE MAGNETICALLY CONNECTED.
                       # THE COIL FROM WHICH ALTERNATING VOLTAGE IS APPLIED IS CALLED PRIMARY COIL
                       # THECOIL FROM WHICH OUTPUT VOLTAGE IS DRAWN IS KNOWN IS SECONDARY COIL.
TYPES OF TRANSFORMERS:
                     #STEP-UP TRANSFORMER
                    #STEP-DOWN TRANSFORMER
STEP -UP TRANSFORMER:
                    #STEP-UP TRANSFORMER BUILDS THE VOLTAGE.
                   #THE VOLTAGE TRANSFORMATION RATIO IS GREATER THAN 1(K>1).
                   # THIS TRANSFORMER HAS LESS NUMBER OF SECONDARY TURNS(N1>N2),SO THERE WILL BE LESS SUPPLY OF CURRENT AND MORE SUPPLY OF VOLTAGE
STEP-DOWN TRANSFORMER:
                    #STEP-DOWN TRANSFORMER REDUES THE INPUT VOLTAGE.
                    #THE VOLTAGE TRANSFORMATION RATIO IS LESSER THAN 1(K<1).
VOLTAGE TRANSFORMATION RATIO:
                            N1/N2 = V1/V2 = I2/I1 = K
                            # K IS KNOWN IS VOLTAGE TRANSFORMATION RATIO.
                            # THIS TRANSFORMER HAS MORE NUMBER OF SECONDARY TURNS(N1<N2),SO THERE WILL BE MORE SUPPLY OF CURRENT AND LESS SUPPLY OF VOLTAGE
EFFICIENCY OF TRANSFORMER:
                         #TRANSFORMERS ARE HIGH EFFICIENT DEVICES.
                         #SINCE TRANSFORMERS HAVE NO MOVING PARTS,SO IT'S EFFICIENCY WILL BE VERY HIGH.
                         #EFFICIENCY OF TRANSFORMER WILL BE IN THE RANGE OF 96% TO 99%.
                         # EFFICIENCY = INPUT POWER/0UTPUT POWER
